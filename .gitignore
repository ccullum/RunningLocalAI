# gitignore template for LangChain products, e.g., LangGraph, LangSmith
# website: https://www.langchain.com/
# website: https://www.langchain.com/langgraph

# Standard Python Environments & Caches
.venv/
.venv - Copy/
venv/
__pycache__/
*.pyc
.env

# LangGraph
.langgraph_api/

# Ignore large AI model files
*.gguf
*.bin
models/

# Ignore sensitive files
*.env

# Ignore Vector DB folders
lancedb_data
qdrant_data
qdrant_storage/
*.db
*.sqlite

# Downloaded Neural Models (TTS / STT)
*.onnx
*.bin
*.pt
*.safetensors
piper-lessac.onnx.json

# Temporary Audio Recordings
*.wav
*.mp3
temp_capture.wav
benchmark_audio.wav
temp_pyttsx3.wav

# Pre-compiled Binaries & Archives
piper/
*.zip

# Ignore the heavy llama.cpp dependency in the experiment folder
src/Lesson-12/experiment/cpp_inference/
src/Lesson-12/experiment/cpp_engine/

# Ignore data/logs/*.csv as there may be data that requires to be cleansed.
data/logs/*.csv

# Allow CSV files only in the Lesson 12 experiment folder
!src/Lesson-12/experiment/*.csv

# streamlit directory and it's files
.streamlit

# =========================
# IDE & Environment Files
# =========================
.vscode/
.idea/
__pycache__/
*.pyc

# =========================
# C++ Build Artifacts
# =========================
# Compiled dynamic libraries (Python C-extensions)
*.pyd
*.so
*.dylib

# Setuptools and Pip metadata
*.egg-info/
build/
dist/
*.whl

# MSVC temporary object and linking files
*.obj
*.lib
*.exp

# =========================
# CMake & Scikit-Build Artifacts
# =========================
_skbuild/
CMakeCache.txt
CMakeFiles/
CMakeScripts/
cmake_install.cmake
Makefile

# MSVC generated project files from CMake
*.vcxproj
*.vcxproj.filters
*.vcxproj.user
*.sln

# Compiled C++ Binaries and outputs
bin/